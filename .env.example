# =============================================================================
# Frontend environment configuration — TEMPLATE ONLY
# -----------------------------------------------------------------------------
# ⚠  This file is committed to git. NEVER put real secrets here.
#
# This app uses Supabase as its only backend (auth, database, storage, RPCs).
# In Lovable, the real `.env` is auto-populated by the Lovable Cloud integration
# and is gitignored. If you fork this project to your own Supabase project,
# replace these with values from your project's API settings.
#
# LOCAL DEV
#   1. Copy:   cp .env.example .env
#   2. Fill in your Supabase URL + publishable (anon) key.
#   3. Start:  npm run dev
#
# Server-only secrets (e.g. SUPABASE_SERVICE_ROLE_KEY) must NEVER be added to
# this file or any VITE_-prefixed variable — they would be inlined into the
# client bundle. Store them as Supabase Edge Function secrets instead.
# =============================================================================

# Your Supabase project URL — e.g. https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase publishable (anon) key — safe to expose to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Your Supabase project ref (the subdomain part of VITE_SUPABASE_URL).
VITE_SUPABASE_PROJECT_ID=your-project-ref
