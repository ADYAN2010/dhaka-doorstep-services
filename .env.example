# =============================================================================
# Frontend environment configuration — TEMPLATE ONLY
# -----------------------------------------------------------------------------
# ⚠  This file is committed to git. NEVER put real secrets here.
# The frontend has NO database access — it only talks to the backend API.
# All MySQL credentials live exclusively in backend/.env (or hPanel env vars).
#
# LOCAL DEV
#   1. Copy:   cp .env.example .env
#   2. Edit:   .env  (gitignored)
#   3. Start:  npm run dev
#
# PRODUCTION
#   Set VITE_API_BASE_URL to your deployed Express backend URL
#   (e.g. https://api.shobsheba.com). Vite inlines it at build time.
# =============================================================================

# Public URL of the Express backend that this frontend will call.
# REQUIRED in production. In dev, defaults to http://localhost:4000.
VITE_API_BASE_URL=https://api.your-domain.com
