# =============================================================================
# Backend environment configuration — TEMPLATE ONLY
# -----------------------------------------------------------------------------
# ⚠  This file is committed to git. NEVER put real credentials here.
#
# LOCAL DEV
#   1. Copy:    cp backend/.env.example backend/.env
#   2. Edit:    backend/.env  (gitignored — your secrets stay on disk)
#   3. Start:   npm --prefix backend run dev
#
# PRODUCTION (Hostinger Cloud / Business — Node.js app)
#   Do NOT upload backend/.env. Instead, in hPanel → Advanced → Node.js
#   (or "Node.js Apps") set each variable below in the "Environment Variables"
#   section. They are injected at process start and read by backend/config/db.js.
#
# If a real password ever lands in this file, ROTATE it in hPanel immediately.
# =============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=production

# Comma-separated allowed origins. Use your real frontend URL(s) in production.
# Example: https://shobsheba.com,https://www.shobsheba.com
CORS_ORIGIN=https://your-frontend-domain.com

# ---- Database (MySQL / Hostinger) ----
# PLACEHOLDERS ONLY — set real values in backend/.env locally,
# or in hPanel → Node.js → Environment Variables in production.
DB_HOST=your_db_host.hstgr.io
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Connection pool tuning
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000

# Set to "true" if your MySQL host requires SSL (most Hostinger shared hosts do NOT).
DB_SSL=false

# ---- Auth (JWT) ----
# REQUIRED. Use a long random string (32+ chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=12h
