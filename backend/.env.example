# =============================================================================
# Backend environment configuration
# -----------------------------------------------------------------------------
# 1. Copy this file:        cp backend/.env.example backend/.env
# 2. Fill in real values    (NEVER commit backend/.env to git)
# 3. Restart the server     npm --prefix backend run dev
# =============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS.
# Use "*" only for local dev. In production, list your real frontend URLs.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---- Database (MySQL / Hostinger) ----
# These are PLACEHOLDERS. Replace with your real credentials in backend/.env.
DB_HOST=srv547.hstgr.io
DB_PORT=3306
DB_NAME=u475884743_shobsheba
DB_USER=u475884743_shobsheba
DB_PASSWORD=|^N|kBZ:k0

# Connection pool tuning
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000

# Set to "true" if your MySQL host requires SSL (most Hostinger shared hosts do NOT).
DB_SSL=false
